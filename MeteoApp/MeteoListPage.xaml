<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeteoApp.MeteoListPage">
    <ContentPage>
        <ContentPage.ToolbarItems>
            <ToolbarItem Text="Add" Clicked="OnItemAdded" />
        </ContentPage.ToolbarItems>

        <ListView x:Name="zlistView" 
                Margin="20, 20, 20, 0" 
                ItemSelected="OnListItemSelected" 
                ItemsSource="{Binding Entries}"
                SeparatorVisibility="Default"
                SeparatorColor="#FF718DD5">
                <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <StackLayout Margin="30,10,0,0" Orientation="Horizontal" HorizontalOptions="FillAndExpand">
                            
                            <StackLayout HorizontalOptions="StartAndExpand" VerticalOptions="Center">
                                <Label Text="{Binding CityName}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding WeatherDescription}" FontSize="14" TextColor="Gray" />
                            </StackLayout>

                            <Label Text="{Binding Temperature, StringFormat='{0}°'}" 
                                   VerticalTextAlignment="Center" 
                                   HorizontalOptions="End" 
                                   FontSize="24" FontAttributes="Bold" />

                        </StackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </ContentPage>
</Shell>