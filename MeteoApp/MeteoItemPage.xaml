<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeteoApp.MeteoItemPage"
             BackgroundColor="#000000"
             Title="{Binding Entry.CityName}">
             
    <ScrollView>
        <VerticalStackLayout x:Name="MainLayout" Spacing="10" Margin="20, 30, 20, 20">
            
            <Label Text="{Binding Entry.CityName}"
                   FontSize="45"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   TextColor="White" />

            <Image Source="{Binding Entry.WeatherIcon}"
                   WidthRequest="150"
                   HeightRequest="150"
                   HorizontalOptions="Center" />

            <Label Text="{Binding Entry.Temperature, StringFormat='{0}°'}"
                   FontSize="100"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="White" 
                   Margin="0, -30, 0, 0" />

            <Label Text="{Binding Entry.WeatherDescription}"
                   FontSize="24"
                   TextColor="#D1E5F9"
                   HorizontalOptions="Center"
                   TextTransform="Uppercase" 
                   Margin="0, 0, 0, 40" /> 
                   
            <Border BackgroundColor="#1C1C1E" 
                    Stroke="Transparent" 
                    Padding="20">
                
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto, Auto" RowSpacing="5">
                    
                    <Label Grid.Row="0" Grid.Column="0" Text="Umidità" TextColor="Gray" FontSize="14" HorizontalOptions="Center" />
                    <Label Grid.Row="0" Grid.Column="1" Text="Nuvole" TextColor="Gray" FontSize="14" HorizontalOptions="Center" />
                    <Label Grid.Row="0" Grid.Column="2" Text="Vento" TextColor="Gray" FontSize="14" HorizontalOptions="Center" />

                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding Entry.Humidity, StringFormat='{0}%'}" TextColor="White" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding Entry.cloudiness, StringFormat='{0}%'}" TextColor="White" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Grid.Row="1" Grid.Column="2" Text="{Binding Entry.WindSpeed, StringFormat='{0} m/s'}" TextColor="White" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                    
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>